# SSH Tunnel Manager 配置文件示例
#
# 隧道类型说明：
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 正向隧道 (tunnel_type: "local")  —— SSH -L 本地端口转发                  │
# │                                                                         │
# │   用途：访问远程服务器上的服务（如远程数据库、Web服务）                     │
# │                                                                         │
# │   流向：本机监听端口 ──→ SSH服务器 ──→ 远端目标端口                       │
# │                                                                         │
# │   示例：本机 13306 ──→ SSH服务器 10.0.0.10 ──→ 远端 MySQL 3306           │
# │         访问本机 13306 即等于访问远程 MySQL                              │
# │                                                                         │
# │   字段含义：                                                             │
# │   - local_bind_port:   本机监听端口（你访问的端口）                       │
# │   - remote_bind_host:  远端目标主机（SSH服务器能访问的内网地址）           │
# │   - remote_bind_port:  远端目标端口（实际服务端口）                        │
# └─────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 反向隧道 (tunnel_type: "remote") —— SSH -R 远程端口转发                  │
# │                                                                         │
# │   用途：让外网访问本机服务（如本地开发的Web应用、内网服务）                │
# │                                                                         │
# │   流向：SSH服务器监听端口 ──→ 本机目标端口                               │
# │                                                                         │
# │   示例：SSH服务器 8080 ──→ 本机 Web服务 8080                             │
# │         外网访问 SSH服务器:8080 即等于访问本机 Web服务                    │
# │                                                                         │
# │   字段含义（注意与正向隧道相反）：                                        │
# │   - local_bind_port:   本机服务端口（被转发的本地服务）                   │
# │   - remote_bind_port:  SSH服务器监听端口（外网访问的端口）                │
# │   - remote_bind_host:  通常为 127.0.0.1（SSH服务器本地监听）              │
# │                                                                         │
# │   前提条件：SSH服务器需开启 GatewayPorts（允许远程端口转发）              │
# └─────────────────────────────────────────────────────────────────────────┘

tunnels:
  # 正向隧道示例：访问远程 MySQL 数据库
  mysql_tunnel:
    ssh_host: 10.0.0.10              # SSH 服务器地址
    ssh_port: 22                     # SSH 端口
    ssh_user: ubuntu                 # SSH 用户名
    ssh_password: null               # 密码（推荐使用私钥）
    ssh_pkey: /home/user/.ssh/id_rsa # 私钥路径
    local_bind_host: 127.0.0.1       # 本机监听地址
    local_bind_port: 13306           # 本机监听端口（访问本机13306=访问远程3306）
    remote_bind_host: 127.0.0.1      # 远端目标主机
    remote_bind_port: 3306           # 远端目标端口（MySQL端口）
    autostart: false                 # 是否自动启动
    tunnel_type: "local"             # 正向隧道（默认值）

  # 反向隧道示例：将本机 Web 服务暴露到外网
  web_tunnel:
    ssh_host: 10.0.0.10              # SSH 服务器地址（需有公网IP）
    ssh_port: 22                     # SSH 端口
    ssh_user: ubuntu                 # SSH 用户名
    ssh_password: null
    ssh_pkey: /home/user/.ssh/id_rsa
    local_bind_host: 127.0.0.1
    local_bind_port: 8080            # 本机服务端口（你的Web应用）
    remote_bind_host: 127.0.0.1      # SSH服务器上监听的地址
    remote_bind_port: 8080           # SSH服务器监听端口（外网访问端口）
    autostart: false
    tunnel_type: "remote"            # 反向隧道

# 反向隧道注意事项：
# 1. SSH服务器需要在 /etc/ssh/sshd_config 中设置 GatewayPorts yes 或 clientspecified
# 2. 确保 SSH服务器防火墙开放 remote_bind_port 端口
# 3. local_bind_port 是你本机运行的服务端口（如 Flask/Django/Node.js）
# 4. 外网访问方式：http://SSH服务器IP:remote_bind_port